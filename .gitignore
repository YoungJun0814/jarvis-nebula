# ==========================================
# Jarvis Nebula — .gitignore
# ==========================================

# --- Environment Variables (NEVER commit) ---
.env
.env.local
.env.*.local

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Vite Build Output ---
dist/
dist-ssr/
*.local

# --- Editor ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Neo4j Local Data (Docker volumes) ---
neo4j-data/
neo4j-logs/
neo4j-import/
neo4j-plugins/

# --- Logs ---
logs/
*.log

# --- Temp ---
tmp/
.tmp/
