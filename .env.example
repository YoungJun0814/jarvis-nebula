# Jarvis Nebula - Environment Variables (template)
# Copy this file to .env and fill in local values. .env is gitignored.

# --- LLM provider --------------------------------------------------------
# Which provider the factory picks by default. One of: cerebras | gemini
LLM_PROVIDER=cerebras

# Cerebras Cloud - https://cloud.cerebras.ai/ (Stage 0 preferred; free tier)
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Google AI Studio - https://aistudio.google.com/app/apikey (fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Legacy graph backend (phase-9 MVP) ---------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# --- App identity -------------------------------------------------------
APP_NAME=Jarvis Nebula
EDGE_TTS_VOICE=en-US-AvaMultilingualNeural
LOG_LEVEL=INFO

# --- Frontend public config --------------------------------------------
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_WS_URL=ws://localhost:8000/ws
