# Jarvis Nebula environment variables
# Planning baseline aligned with PROJECT_PLAN.md section 11.
# Copy this file to .env and fill in local values before implementation.
#
# Important:
# - Secrets must stay backend-only.
# - Only public browser-safe values may use the VITE_ prefix.

# Backend secrets
GEMINI_API_KEY=your_gemini_api_key_here

# Backend service config
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
APP_NAME=Jarvis Nebula
EDGE_TTS_VOICE=en-US-AvaMultilingualNeural
LOG_LEVEL=INFO

# Frontend public config
VITE_WS_URL=ws://localhost:8000/ws
